{
  "name": "blackbox",
  "version": "0.1.0",
  "private": true,
  "description": "Blackbox — browser session recorder (Chrome/Edge extension) + client-side replay viewer.",
  "workspaces": [
    "shared",
    "extension",
    "viewer",
    "firefox"
  ],
  "scripts": {
    "build:extension": "npm run build --workspace extension",
    "build:firefox": "npm run build --workspace firefox",
    "build:viewer": "npm run build --workspace viewer",
    "build": "npm run build:extension && npm run build:firefox && npm run build:viewer",
    "dev:viewer": "npm run dev --workspace viewer",
    "dev:extension": "npm run dev --workspace extension",
    "sample": "node scripts/make-sample.mjs",
    "icons": "node scripts/make-icons.mjs",
    "package:extension": "npm run build:extension && node scripts/package-extension.mjs",
    "package:firefox": "npm run build:firefox && node scripts/package-firefox.mjs",
    "package:firefox-src": "git archive --format=zip -o blackbox-source.zip HEAD"
  },
  "devDependencies": {
    "sharp": "^0.35.2"
  }
}
